{
  "name": "agent-code-review",
  "version": "1.0.0",
  "private": true,
  "description": "Reusable GitHub Action: AI code review via OpenRouter, posted as a single PR comment.",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist",
    "typecheck": "tsc --noEmit",
    "all": "npm run typecheck && npm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.3",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
